#服务端口
SERVER_PORT=5001

#Timezone
TZ=Asia/Shanghai

# ==============================================
# 大模型供应商配置（按 LLM_PROVIDER 选择对应厂商）
# ==============================================
# 系统根据 LLM_PROVIDER 读取对应厂商的 KEY / BASE_URL / MODEL。
# 未启用的厂商保留默认占位即可，但 KEY 必须正确填入才能使用。
# 注意：Ollama 在 Docker 部署下走 host.docker.internal，宿主机部署需改为 127.0.0.1。

#大模型供应商配置,支持 deepseek, openai, zhipuai, qwen, ollama 和 anthropic
LLM_PROVIDER=deepseek

#DeepSeek settings
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_MODEL=deepseek-chat

#OpenAI settings
OPENAI_API_KEY=xxxx
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_MODEL=gpt-4o-mini

#ZhipuAI settings
ZHIPUAI_API_KEY=xxxx
ZHIPUAI_API_MODEL=GLM-4-Flash

#Qwen settings
QWEN_API_KEY=sk-xxx
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_MODEL=qwen-coder-plus

#OllaMA settings; 注意: 如果使用 Docker 部署，127.0.0.1 指向的是容器内部的地址。请将其替换为实际的 Ollama服务器IP地址。
#OLLAMA_API_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_MODEL=deepseek-r1:latest

#Anthropic Claude settings
ANTHROPIC_API_KEY=xxxx
ANTHROPIC_API_BASE_URL=xxxx
ANTHROPIC_API_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=4096

# ==============================================
# 代码 Review 主配置
# ==============================================
# 控制 Review 行为的基础参数：支持的文件后缀、上下文 Token 上限与风格。
# 注意：SUPPORTED_EXTENSIONS 修改后需重启服务才生效。

#支持review的文件类型
SUPPORTED_EXTENSIONS=.c,.cc,.cpp,.cs,.css,.cxx,.go,.h,.hh,.hpp,.hxx,.java,.js,.jsx,.md,.php,.py,.sql,.ts,.tsx,.vue,.yml
#每次 Review 的最大 Token 限制（超出部分自动截断）
REVIEW_MAX_TOKENS=10000
#Review 风格选项：professional（专业） | sarcastic（毒舌） | gentle（温和） | humorous（幽默）
REVIEW_STYLE=professional

# ==============================================
# Agentic Review 模式配置（可选）
# ==============================================
# 启用 agentic 后，LLM 可通过工具调用（read_file / 沙箱 shell）
# 在本地克隆的代码库内自主探索，产出更全面的 review 结果。
# 任意阶段失败都会自动降级回 diff_only，保证至少返回与原版一致的 review。
# 注意：该模式会按需在 REPO_CACHE_DIR 下克隆/更新目标项目（建议预留 ≥ 50GB 磁盘）。
# 鉴权：agentic 模式会按 host 自动从下方代码托管平台 Token 中选一个注入到
#       clone/fetch 的 URL 里，避免容器内无凭据导致失败。
#       github.com / *.github.com → GITHUB_ACCESS_TOKEN
#       包含 gitea 的 host         → GITEA_ACCESS_TOKEN
#       其余（含自建 GitLab）       → GITLAB_ACCESS_TOKEN

#Review 策略：diff_only（默认，仅 review diff） | agentic（工具调用探索全项目）
REVIEW_STRATEGY=diff_only
#Agentic 模式下本地仓库缓存根目录
REPO_CACHE_DIR=data/repo_cache
#单次工具输出超过此 token 数时自动截断
AGENT_TOOL_OUTPUT_MAX_TOKENS=10000
#Shell 工具白名单覆盖（逗号分隔；留空使用内置默认值，仅允许读类命令）
#AGENT_SHELL_ALLOWLIST=ls,cat,head,tail,grep,find,wc,git
#Shell 工具黑名单覆盖（逗号分隔；留空使用内置默认值）
#AGENT_SHELL_BLOCKLIST=rm,mv,cp,chmod,chown,curl,wget,sudo

# ==============================================
# 通知渠道配置
# ==============================================
# 支持钉钉 / 企业微信 / 飞书 / 自定义 Webhook 四种渠道。
# 启用任一渠道时，将对应 ENABLED 置 1 并填写 Webhook URL。
# 注意：仅钉钉支持”加签”校验（启用需设置 DINGTALK_SECRET_ENABLED=1），
#       企业微信和飞书仅依赖 Webhook URL。

#钉钉配置
DINGTALK_ENABLED=0
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_SECRET_ENABLED=0   # 启用加签（仅钉钉支持）
DINGTALK_SECRET=SECxxx

#企业微信配置
WECOM_ENABLED=0
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

#飞书配置
FEISHU_ENABLED=0
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

#自定义webhook配置，使用场景：通过飞书发送应用消息可以实现Push评审通知到提交人，在自定义webhook里可以实现各种定制通知功能
#参数EXTRA_WEBHOOK_URL接收POST请求，data={ai_codereview_data: {}, webhook_data: {}}，ai_codereview_data为本系统通知的数据，webhook_data为原github、gitlab hook触发的数据
EXTRA_WEBHOOK_ENABLED=0
EXTRA_WEBHOOK_URL=https://xxx/xxx

# ==============================================
# 日志配置
# ==============================================
# 控制日志文件路径、滚动策略和输出级别。
# 注意：生产环境建议使用 INFO 或 WARNING，DEBUG 会输出每轮 assistant 内容与工具调用详情，token 量较大。

#日志配置
LOG_FILE=log/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3
# 日志级别：DEBUG 输出每轮 assistant 内容和每次工具调用的 name/args/result（排查用），
# INFO 只输出每轮汇总（每条 review 一行结构化 + 降级原因）。
# 可选：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=DEBUG

#工作日报发送时间
REPORT_CRONTAB_EXPRESSION=0 18 * * 1-5

# ==============================================
# 代码托管平台（按需启用其一）
# ==============================================
# 取消对应平台的注释并填入 Token 即可启用，Webhook 端无需额外配置 URL。
# 注意：Gitlab 老版本 webhook 不传 URL 时需显式设置 GITLAB_URL；
#       Gitlab 优先使用此处的 GITLAB_ACCESS_TOKEN，未配置时回退到 Webhook 传递的 Secret Token。

#Gitlab配置
#GITLAB_URL={YOUR_GITLAB_URL} #部分老版本Gitlab webhook不传递URL，需要开启此配置，示例：https://gitlab.example.com
#GITLAB_ACCESS_TOKEN={YOUR_GITLAB_ACCESS_TOKEN} #系统会优先使用此GITLAB_ACCESS_TOKEN，如果未配置，则使用Webhook 传递的Secret Token

#Github配置(如果使用 Github 作为代码托管平台，需要配置此项)
#GITHUB_ACCESS_TOKEN={YOUR_GITHUB_ACCESS_TOKEN}

#Gitea配置(如果使用 Gitea 作为代码托管平台，需要配置此项)
# GITEA_ACCESS_TOKEN={YOUR_GITEA_ACCESS_TOKEN}
# GITEA_URL={YOUR_GITEA_URL}

# ==============================================
# 触发策略
# ==============================================
# 控制 push 事件和 Merge 请求是否触发 Review。
# 注意：MERGE_REVIEW_ONLY_PROTECTED_BRANCHES_ENABLED=1 时，
#       仅当合并目标分支为受保护分支时才 Review，需先在 Git 平台配置 protected branches。

# 开启Push Review功能(如果不需要push事件触发Code Review，设置为0)
PUSH_REVIEW_ENABLED=1
# 开启Merge请求过滤，过滤仅当合并目标分支是受保护分支时才Review(开启此选项请确保仓库已配置受保护分支protected branches)
MERGE_REVIEW_ONLY_PROTECTED_BRANCHES_ENABLED=0

# ==============================================
# Dashboard 认证
# ==============================================
# Web Dashboard 登录凭据；首次部署后请立即修改默认值。
# 注意：凭据以明文存于配置文件，请确保文件权限受控（建议 600）。

# Dashboard登录用户名和密码
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=admin

# 原有LLM Review开关(设置为0则不通过内置LLM进行Code Review)
LLM_REVIEW_ENABLED=1

# OpenCode Agent Review配置
# 开启后webhook收到事件时会将请求发送到opencode serve的API进行review
OPENCODE_ENABLED=0
OPENCODE_API_URL=http://0.0.0.0:4096
OPENCODE_AGENT_NAME=code-reviewer
# 如果 OpenCode 服务器启用了认证（设置了 OPENCODE_SERVER_PASSWORD），需要配置以下两项
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=your-password

# ==============================================
# Worker 任务队列
# ==============================================
# 队列名前缀，须与 Git 平台域名 slug 一致（用作 Celery 路由键）。
# 命名规则：<host slug>_<top-level-domain>，例：gitlab.example.com → git_example_com。
# 多实例部署时队列名必须保持一致，否则消息无法路由。

# gitlab domain slugged
WORKER_QUEUE=git_test_com
